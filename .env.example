# Cruise Notifier — copy this to .env and fill in your values

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Pushover
PUSHOVER_API_TOKEN=
PUSHOVER_USER_KEY=

# Discord
DISCORD_WEBHOOK_URL=

# Gmail (optional — uncomment send_email_message in cruise.notify.py to use)
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_RECIPIENT=

# Log directory (optional — defaults to ./logs next to the script)
# LOG_DIRECTORY=F:\kvcd22\SYNCTHING\Script_Master\IP1\workroom\NOTIFICATION\logs

# Reminder settings
MAX_DAYS_FOR_REMINDER=65
RUN_REMINDERS=true
